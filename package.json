{
  "name": "studentnest",
  "version": "8.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate && node scripts/patch-prisma-wasm.js",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "pages:clean": "node -e \"const fs=require('fs');['.open-next','.cf-deploy','.next'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}));console.log('✓ cleaned .open-next .cf-deploy .next');\"",
    "pages:build": "npm run pages:clean && npx prisma generate && node scripts/patch-prisma-wasm.js && opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && node scripts/prepare-cf-deploy.js",
    "release:check": "node scripts/pre-release-check.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "smoke-tests": "node scripts/smoke-tests.js",
    "integration-tests": "node scripts/integration-tests.js",
    "check-pwa": "node scripts/check-pwa.js",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:preview": "node -e \"process.env.E2E_BASE_URL=process.env.E2E_BASE_URL||'https://studentnest.pages.dev'\" && playwright test",
    "ap:audit": "node scripts/ap-audit-questions.js",
    "ap:audit:fix": "node scripts/ap-audit-questions.js --fix",
    "ap:review": "node scripts/ap-ai-review-questions.js",
    "ap:review:fix": "node scripts/ap-ai-review-questions.js --fix",
    "pages:deploy:staging": "node scripts/deploy-staging.js",
    "pages:promote": "node scripts/deploy-promote.js",
    "pages:deploy": "(node scripts/pre-release-check.js && vitest run && npm run pages:build && wrangler pages deploy .cf-deploy --project-name=studentnest --commit-dirty=true && node scripts/smoke-tests.js && node scripts/functional-tests.js && node scripts/integration-tests.js && playwright test --reporter=list && node scripts/update-test-plan.js && node scripts/archive-release.js) && (node scripts/send-deploy-email.js --status=success) || (node scripts/send-deploy-email.js --status=failed && exit 1)",
    "pages:deploy:direct": "echo '⚠️  pages:deploy uploads straight to PRODUCTION before tests run. Use npm run pages:deploy:staging then npm run pages:promote instead. Press Ctrl-C now if unsure.' && sleep 3 && npm run pages:deploy",
    "pages:preview": "npm run pages:build && wrangler pages dev .cf-deploy"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@neondatabase/serverless": "^0.9.3",
    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/adapter-neon": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@sentry/nextjs": "^10.50.0",
    "bcrypt-ts": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "katex": "^0.16.45",
    "lucide-react": "^0.454.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.3",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "stripe": "^16.12.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "wrangler": "^4.72.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "knip": "^6.6.2",
    "postcss": "^8.4.47",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vercel": "^50.32.3",
    "vitest": "^4.1.5"
  }
}
