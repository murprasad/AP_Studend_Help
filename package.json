{
  "name": "studentnest",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate && node scripts/patch-prisma-wasm.js",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "pages:build": "npx prisma generate && node scripts/patch-prisma-wasm.js && opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && node scripts/prepare-cf-deploy.js",
    "pages:deploy": "node scripts/check-cf-compat.js && npm run pages:build && wrangler pages deploy .cf-deploy --project-name=studentnest --commit-dirty=true && node scripts/post-deploy-verify.js",
    "pages:preview": "npm run pages:build && wrangler pages dev .cf-deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@auth/prisma-adapter": "^2.7.2",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@huggingface/inference": "^4.13.15",
    "@neondatabase/serverless": "^0.9.3",
    "@netlify/blobs": "^10.7.0",
    "@netlify/functions": "^5.1.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/adapter-neon": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "bcrypt-ts": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cohere-ai": "^7.20.0",
    "date-fns": "^4.1.0",
    "groq-sdk": "^0.37.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.454.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.3",
    "remark-gfm": "^4.0.1",
    "stripe": "^16.12.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "wrangler": "^4.72.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.47",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vercel": "^50.32.3"
  }
