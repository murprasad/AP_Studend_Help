enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  FRQ
  SAQ
  DBQ
  LEQ
  NUMERICAL
  CODING
  DATA_ANALYSIS
}

enum SessionType {
  QUICK_PRACTICE
  FOCUSED_STUDY
  MOCK_EXAM
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
