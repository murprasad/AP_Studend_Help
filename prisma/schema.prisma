generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  passwordHash      String?
  firstName         String
  lastName          String
  gradeLevel        String
  school            String?
  role              Role      @default(STUDENT)
  subscriptionTier         SubTier   @default(FREE)
  stripeSubscriptionId     String?
  stripeCurrentPeriodEnd   DateTime?
  stripeSubscriptionStatus String?   // 'active' | 'canceling' | 'canceled'
  avatarUrl                String?
  streakDays        Int       @default(0)
  longestStreak     Int       @default(0)
  lastActiveDate    DateTime?
  totalXp           Int       @default(0)
  level             Int       @default(1)
  streakFreezes     Int       @default(0)  // streak freeze tokens
  examDate          DateTime?              // AP exam date for countdown
  track             String    @default("ap")  // "ap" | "clep"
  freeTrialExpiresAt   DateTime?              // 7-day trial window end
  freeTrialCourse      String?                // course trial is scoped to
  trialEmailsSent      Int       @default(0)  // re-engagement email count (cap at 3)
  onboardingCompletedAt DateTime?             // null = send to /onboarding on next login
  dailyQuizOptIn    Boolean   @default(false)    // opt-in for the "Daily Quiz Email" feature; flipped via Settings toggle
  dailyQuizTz       String?                      // IANA tz (e.g. "America/Chicago"); null = UTC default at 7:30
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Location captured on most recent dashboard load via CF Workers request
  // headers (cf-ipcountry / cf-region / cf-city / cf-postal-code). Free of
  // charge with CF, no paid geolocation service. Used in the admin Recent
  // Signups + Users tabs to understand acquisition geography.
  lastLoginCountry      String?
  lastLoginRegion       String?
  lastLoginCity         String?
  lastLoginPostalCode   String?
  lastLoginLocationAt   DateTime?

  sessions          Session[]
  accounts          Account[]
  verificationTokens VerificationToken[]
  passwordResets    PasswordResetToken[]
  practiceSessions  PracticeSession[]
  responses         StudentResponse[]
  masteryScores     MasteryScore[]
  masteryGoals      MasteryGoal[]
  studyPlans        StudyPlan[]
  achievements      UserAchievement[]
  tutorConversations TutorConversation[]
  questionReports     QuestionReport[]
  diagnosticResults   DiagnosticResult[]
  discussionThreads   DiscussionThread[]
  discussionReplies   DiscussionReply[]
  sessionFeedbacks    SessionFeedback[]
  tutorKnowledgeChecks TutorKnowledgeCheck[]
  moduleSubscriptions  ModuleSubscription[]
  trialReengagements   TrialReengagement[]
  dailyQuizSends       DailyQuizSend[]
  masteryTierUps       MasteryTierUp[]
  frqAttempts          FrqAttempt[]
  dashboardImpressions DashboardImpression[]
  sageCoachSessions    SageCoachSession[]
  flashcardReviews     FlashcardReview[]

  @@map("users")
}

// Dashboard → Coach Card → CTA click funnel instrumentation.
// One row per dashboard page load. Subsequent events (coach_requested /
// coach_rendered / coach_clicked) patch the same row so we can measure
// where users drop off after login without joining multiple tables.
//
// Privacy note: no IP / user-agent / device data is captured — only the
// event timestamps, the course the user was viewing, and the coach's
// CTA type + rough projected score at render time.
model DashboardImpression {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Which course the user was viewing
  course                String
  // Event timeline (per dashboard view)
  dashboardLoadedAt     DateTime @default(now())
  coachPlanRequestedAt  DateTime?
  coachPlanRenderedAt   DateTime?
  coachPlanCtaClickedAt DateTime?
  // Content at render time so we can correlate click-through with tier
  ctaType               String?  // e.g. "diagnostic_soft" | "fix_weak_unit" | "mock_exam" | "daily_review"
  roughScore            Float?   // projected score shown

  @@index([userId, dashboardLoadedAt])
  @@index([dashboardLoadedAt])
  @@map("dashboard_impressions")
}

// Append-only raw funnel event log. Exists alongside DashboardImpression
// so that every event POST writes a row regardless of whether the client's
// impressionId joins to a real row. Synthetic `client_*` / `fallback_*`
// ids from the client race-fallback path still land here. Reports read
// this table when the aggregated counters disagree with activity data.
model FunnelEvent {
  id            String   @id @default(cuid())
  userId        String
  event         String   // "loaded" | "coach_requested" | "coach_rendered" | "coach_clicked"
  course        String?
  impressionId  String?  // may be a synthetic client_/fallback_ id
  ctaType       String?
  roughScore    Float?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("funnel_events")
}

// ── Flashcard System (ported from PrepLion 2026-04-22) ──────────────────
//
// Flashcards differentiate StudentNest from Khan Academy by offering
// SM-2 spaced-repetition with 8 card shapes optimized for exam prep.
// See src/lib/spaced-repetition.ts for the scheduler and (soon)
// src/lib/flashcard-gen.ts for the content generator.

enum FlashcardType {
  RECALL
  APPLICATION
  CLOZE
  MISCONCEPTION
  COMPARE_CONTRAST
  SEQUENCE
  DIAGRAM
  EXAM_TIP
}

model Flashcard {
  id            String        @id @default(cuid())
  course        ApCourse
  unit          ApUnit
  topic         String
  concept       String
  cardType      FlashcardType
  difficulty    Difficulty    @default(MEDIUM)
  front         String        @db.Text
  back          String        @db.Text
  explanation   String        @db.Text
  cardData      Json?
  hints         Json?
  examRelevance Float         @default(0.5)
  bloomLevel    String?
  contentHash   String        @unique
  isApproved    Boolean       @default(true)
  version       Int           @default(1)
  modelUsed     String?
  // userId is nullable — global deck rows have null; per-user decks set it
  userId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reviews       FlashcardReview[]

  @@index([course, unit, cardType, difficulty])
  @@index([course, concept])
  @@index([userId, unit, cardType])
  @@map("flashcards")
}

model FlashcardReview {
  id              String    @id @default(cuid())
  userId          String
  flashcardId     String
  rating          Int       // 0=Forgot, 1=Hard, 2=Good, 3=Easy
  responseTimeMs  Int       @default(0)
  // SM-2 state at the moment of this review — denormalized so we can
  // rebuild the history without relying on a separate state table.
  easeFactor      Float     @default(2.5)
  interval        Int       @default(1)
  repetitions     Int       @default(0)
  nextReviewAt    DateTime
  reviewedAt      DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard       Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@index([userId, flashcardId, reviewedAt])
  @@index([userId, nextReviewAt])
  @@map("flashcard_reviews")
}

// "You fixed it" — mastery tier-up celebration ledger.
// One row inserted whenever a practice session pushes a unit's masteryScore
// across a tier boundary (0→20, 20→40, 40→60, 60→80, 80→100). The dashboard
// and session summary read unshown rows and render a celebration card, then
// PATCH shownAt to clear the celebration.
model MasteryTierUp {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      ApCourse
  unit        ApUnit
  beforeScore Float    // mastery % before this session
  afterScore  Float    // mastery % after
  beforeTier  Int      // 0=0-19, 1=20-39, 2=40-59, 3=60-79, 4=80-100
  afterTier   Int
  sessionId   String?  // which practice session triggered it
  createdAt   DateTime @default(now())
  shownAt     DateTime? // null until user has seen the celebration

  @@index([userId, createdAt])
  @@map("mastery_tier_ups")
}

model TrialReengagement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailType String   // "first_nudge" | "urgency" | "last_chance"
  course    String   // ApCourse the user is trialing, for analytics slicing
  sentAt    DateTime @default(now())

  @@index([userId, sentAt])
  @@map("trial_reengagements")
}

// Record of each "Daily Quiz Email" sent. One row per successful send.
// The cron at /api/cron/daily-quiz inserts; /api/daily-quiz-track updates
// openedAt (pixel) and answeredAt (from practice page when the matching
// question is answered). Dedup rule: the cron skips questions that appear
// on any row for this user in the last 30 days, to keep variety high.
model DailyQuizSend {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAt            DateTime  @default(now())
  course            String    // course these 3 questions were pulled from (ApCourse value)
  emailToken        String    @unique // UUID — embedded in every deep-link for this send
  weakQuestionId    String
  boosterQuestionId String
  trapQuestionId    String
  openedAt          DateTime?
  answeredAt        DateTime?

  @@index([userId, sentAt])
  @@map("daily_quiz_sends")
}

// Anonymous lead captured from /am-i-ready exit-intent modal. No User FK —
// these are visitors who haven't registered. When they later register with
// the same email, the onboarding flow can link their result history.
model AmIReadyLead {
  id          String   @id @default(cuid())
  email       String
  course      String   // ApCourse value — string (not enum) so we can accept
                       // future courses without enum migrations.
  family      String   // "AP" | "SAT" | "ACT"
  scaledScore Float
  courseName  String
  source      String   @default("exit_intent") // future: "footer_capture", "cta_bar", etc.
  emailedAt   DateTime?
  convertedAt DateTime? // set when this email signs up
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("am_i_ready_leads")
}

model ModuleSubscription {
  id                     String    @id @default(cuid())
  userId                 String
  module                 String    // "ap" | "sat" | "act" | "clep"
  status                 String    @default("active") // "active" | "canceling" | "canceled"
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, module])
  @@map("module_subscriptions")
}

model MasteryGoal {
  id          String    @id @default(cuid())
  userId      String
  course      ApCourse
  unit        ApUnit
  targetScore Float
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, course, unit])
  @@map("mastery_goals")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Question {
  id           String       @id @default(cuid())
  course       ApCourse     @default(AP_WORLD_HISTORY)
  unit         ApUnit
  topic        String
  subtopic     String?
  difficulty   Difficulty
  questionType QuestionType
  questionText String       @db.Text
  stimulus          String?      @db.Text
  stimulusImageUrl  String?      @db.Text
  options           Json?
  correctAnswer String
  explanation  String       @db.Text
  isAiGenerated Boolean     @default(false)
  isApproved   Boolean      @default(true)
  modelUsed          String?
  generatedForTier   SubTier   @default(FREE)
  contentHash        String?   @unique  // SHA-256 of normalized questionText — prevents duplicates
  apSkill            String?            // e.g., "Causation", "Comparison", "Data Analysis"
  bloomLevel         String?            // "remember" | "apply" | "analyze" — Bloom's taxonomy level
  timesAnswered Int         @default(0)
  timesCorrect  Int         @default(0)
  reportedCount Int         @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  responses    StudentResponse[]
  sessionQuestions SessionQuestion[]
  reports      QuestionReport[]

  @@index([course, unit, difficulty, questionType])
  @@map("questions")
}

model PracticeSession {
  id           String      @id @default(cuid())
  userId       String
  course       ApCourse    @default(AP_WORLD_HISTORY)
  sessionType  SessionType
  status       SessionStatus @default(IN_PROGRESS)
  totalQuestions Int        @default(0)
  correctAnswers Int        @default(0)
  timeSpentSecs Int         @default(0)
  startedAt    DateTime     @default(now())
  completedAt  DateTime?
  score        Float?
  apScoreEstimate Int?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions SessionQuestion[]
  responses StudentResponse[]
  feedback  SessionFeedback?

  @@index([userId, course, completedAt])
  @@index([userId, startedAt])
  @@index([userId, course])
  @@map("practice_sessions")
}

model SessionQuestion {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  order      Int

  session  PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("session_questions")
}

model StudentResponse {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  sessionId     String?
  studentAnswer String
  isCorrect     Boolean
  timeSpentSecs Int      @default(0)
  answeredAt    DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question         @relation(fields: [questionId], references: [id])
  session  PracticeSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, questionId, sessionId])
  @@index([userId, sessionId])
  @@map("student_responses")
}

model MasteryScore {
  id             String   @id @default(cuid())
  userId         String
  course         ApCourse @default(AP_WORLD_HISTORY)
  unit           ApUnit
  masteryScore   Float    @default(0)
  accuracy       Float    @default(0)
  totalAttempts  Int      @default(0)
  correctAttempts Int     @default(0)
  avgTimeSecs    Float    @default(0)
  lastPracticed  DateTime?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unit])
  @@map("mastery_scores")
}

model StudyPlan {
  id           String   @id @default(cuid())
  userId       String
  course       ApCourse @default(AP_WORLD_HISTORY)
  planData     Json
  generatedAt  DateTime @default(now())
  isActive     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_plans")
}

model Achievement {
  id          String @id @default(cuid())
  name        String @unique
  description String
  iconName    String
  xpReward    Int    @default(0)
  condition   Json

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model TutorConversation {
  id        String         @id @default(cuid())
  userId    String
  course    ApCourse       @default(AP_WORLD_HISTORY)
  messages  Json
  topic     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("tutor_conversations")
}

model SessionFeedback {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  userId       String
  rating       Int      // 1 = thumbs up, -1 = thumbs down
  feedbackText String?  @db.Text  // A22.6 port — prompted on thumbs-down + abandon path
  context      String?  // A22.6 port — "completion" | "abandon"; null = legacy "completion"
  createdAt    DateTime @default(now())

  session PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session_feedback")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

