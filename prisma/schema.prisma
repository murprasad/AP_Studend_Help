enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  FRQ
  SAQ
  DBQ
  LEQ
  NUMERICAL
  CODING
  DATA_ANALYSIS
}

enum SessionType {
  QUICK_PRACTICE
  FOCUSED_STUDY
  MOCK_EXAM
  DIAGNOSTIC
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model QuestionReport {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  reason     String
  details    String?  @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([questionId, userId])
  @@index([status, createdAt])
  @@map("question_reports")
}

model DiscussionThread {
  id               String   @id @default(cuid())
  userId           String
  course           ApCourse @default(AP_WORLD_HISTORY)
  title            String
  body             String   @db.Text
  isPinned         Boolean  @default(false)
  isRemoved        Boolean  @default(false)
  moderationReason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@index([course, createdAt])
  @@index([course, isRemoved, createdAt])
  @@map("discussion_threads")
}

model DiscussionReply {
  id               String   @id @default(cuid())
  threadId         String
  userId           String
  body             String   @db.Text
  isAiTutor        Boolean  @default(false)
  isRemoved        Boolean  @default(false)
  moderationReason String?
  createdAt        DateTime @default(now())

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("discussion_replies")
}

model TutorKnowledgeCheck {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  course         ApCourse
  topic          String?
  questions      Json     // [{question, options:[4 strings], correctIndex:0-3, explanation}]
  answers        Json     // [2, 0, 1] — user's chosen index per question
  score          Int      // 0–3
  completedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, course])
  @@map("tutor_knowledge_checks")
}

model DiagnosticResult {
  id           String   @id @default(cuid())
  userId       String
  course       ApCourse @default(AP_WORLD_HISTORY)
  sessionId    String?
  unitScores   Json
  weakUnits    Json
  strongUnits  Json
  recommendation String? @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, course, createdAt])
  @@map("diagnostic_results")
}

model AiResponseCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  course    String
  response  String   @db.Text
  followUps String   @db.Text    // JSON array
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("ai_response_cache")
}

