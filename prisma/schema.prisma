  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  FRQ
  SAQ
  DBQ
  LEQ
  NUMERICAL
  CODING
  DATA_ANALYSIS
}

enum SessionType {
  QUICK_PRACTICE
  FOCUSED_STUDY
  MOCK_EXAM
  DIAGNOSTIC
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model QuestionReport {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  reason     String
  details    String?  @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([questionId, userId])
  @@index([status, createdAt])
  @@map("question_reports")
}

model DiscussionThread {
  id               String   @id @default(cuid())
  userId           String
  course           ApCourse @default(AP_WORLD_HISTORY)
  title            String
  body             String   @db.Text
  isPinned         Boolean  @default(false)
  isRemoved        Boolean  @default(false)
  moderationReason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@index([course, createdAt])
  @@index([course, isRemoved, createdAt])
  @@map("discussion_threads")
}

model DiscussionReply {
  id               String   @id @default(cuid())
  threadId         String
  userId           String
  body             String   @db.Text
  isAiTutor        Boolean  @default(false)
  isRemoved        Boolean  @default(false)
  moderationReason String?
  createdAt        DateTime @default(now())

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("discussion_replies")
}

model TutorKnowledgeCheck {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  course         ApCourse
  topic          String?
  questions      Json     // [{question, options:[4 strings], correctIndex:0-3, explanation}]
  answers        Json     // [2, 0, 1] — user's chosen index per question
  score          Int      // 0–3
  completedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, course])
  @@map("tutor_knowledge_checks")
}

model DiagnosticResult {
  id           String   @id @default(cuid())
  userId       String
  course       ApCourse @default(AP_WORLD_HISTORY)
  sessionId    String?
  unitScores   Json
  weakUnits    Json
  strongUnits  Json
  recommendation String? @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, course, createdAt])
  @@map("diagnostic_results")
}

model AiResponseCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  course    String
  response  String   @db.Text
  followUps String   @db.Text    // JSON array
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("ai_response_cache")
}

model SageFAQ {
  id          String   @id @default(cuid())
  category    String   // "how_to_use" | "strategy" | "exam_info" | "pricing" | "troubleshooting"
  question    String
  answer      String   @db.Text
  priority    Int      @default(5)
  tags        String[]
  sourceUrl   String?  // e.g. Reddit post that seeded this FAQ
  corroborationCount Int @default(1)  // how many independent sources said this
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, priority])
  @@map("sage_faq")
}

// ── FRQ (Free-Response Question) Pipeline ─────────────────────────────────────
// Past-exam FRQs with official rubrics. Student writes a response, then reveals
// the rubric + sample response and self-scores. No AI grading initially.
// Cluster A: AP Physics 1, Calc AB, Calc BC, Biology, Chemistry, Statistics.

enum FrqType {
  SHORT          // Physics/Chem "short" FRQ
  LONG           // Physics/Chem "long" FRQ
  MULTI_PART     // Calc multi-part
  INVESTIGATIVE  // Stats 6th Q
  SAQ            // History short-answer
  DBQ            // History document-based
  LEQ            // History long essay
  AAQ            // Psych article analysis
  EBQ            // Psych evidence-based
}

model FreeResponseQuestion {
  id             String    @id @default(cuid())
  course         ApCourse
  unit           ApUnit?   // null if spans multiple units
  year           Int       // exam year, e.g. 2023
  questionNumber Int       // Q1-Q7 etc.
  type           FrqType
  sourceUrl      String    // apcentral.collegeboard.org URL
  promptText     String    @db.Text  // the student-facing prompt
  stimulus       String?   @db.Text  // docs/graphs/tables (may be long)
  totalPoints    Int
  rubric         Json      // [{step: "...", points: 2, keywords: [...], note: "..."}]
  sampleResponse String?   @db.Text  // released scoring commentary / high-scoring sample
  isApproved     Boolean   @default(false)
  createdAt      DateTime  @default(now())

  attempts       FrqAttempt[]

  @@index([course, unit])
  @@index([course, year])
  @@map("free_response_questions")
}

model FrqAttempt {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  frqId         String
  frq           FreeResponseQuestion @relation(fields: [frqId], references: [id], onDelete: Cascade)
  studentText   String               @db.Text  // what the student wrote
  selfScore     Int?                 // student's self-grade vs rubric
  revealed      Boolean              @default(false)
  submittedAt   DateTime             @default(now())

  @@index([userId, submittedAt])
  @@map("frq_attempts")
}


// ──────────────────────────────────────────────────────────────────────────
// OfficialSample — reference material scraped from official exam sources.
//
// Used as RAG grounding for our question generator (NOT served verbatim
// to students — those sample questions are copyrighted by their
// respective bodies). We pull style, rigor, topic coverage, and
// pseudocode conventions from these rows at generation time.
//
// licenseNotes should be set on every row (e.g. "© College Board 2024 —
// reference-only under fair use; do not serve verbatim").
// ──────────────────────────────────────────────────────────────────────────
model OfficialSample {
  id            String   @id @default(cuid())
  course        String   // ApCourse value (or "SAT_*", "ACT_*")
  unit          String?  // ApUnit value; null if the sample spans units
  year          Int?     // publication / exam year
  sourceUrl     String
  sourceName    String   // "CollegeBoard AP Central" / "ACT.org" / "Khan Academy SAT"
  questionText  String   @db.Text
  stimulus      String?  @db.Text
  options       Json?    // mirrors Question.options shape when MCQ
  correctAnswer String?
  explanation   String?  @db.Text
  questionType  String   @default("MCQ") // MCQ | FRQ | SAQ | DBQ | LEQ | etc.
  licenseNotes  String?  @db.Text
  ingestedAt    DateTime @default(now())

  @@index([course, unit])
  @@index([course, questionType])
  @@map("official_samples")
}

// ── Sage Coach ───────────────────────────────────────────────────────────
// Oral-response training: timed voice answers evaluated by Haiku 4.5 across
// 5 dimensions (accuracy/coverage/structure/clarity/confidence). Positioning
// is "Explain-to-pass", NOT flashcards-with-voice. See memory
// project_sage_coach_prd.md for full spec.

model SageCoachConcept {
  id         String   @id @default(cuid())
  course     ApCourse
  unit       ApUnit
  concept    String
  question   String   @db.Text
  difficulty String   @default("basic") // "basic" | "intermediate" | "advanced"
  keyPoints  String[]
  createdAt  DateTime @default(now())

  sessions   SageCoachSession[]

  @@index([course, unit, difficulty])
  @@map("sage_coach_concepts")
}

model SageCoachSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conceptId        String
  concept          SageCoachConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  course           ApCourse
  transcript       String   @db.Text
  audioDurationMs  Int      @default(0)
  scores           Json     // {accuracy, coverage, structure, clarity, confidence}
  missingKeyPoints String[]
  summary          String   @db.Text
  specificFeedback String   @db.Text
  improvementTip   String   @db.Text
  retryOf          String?
  createdAt        DateTime @default(now())

  @@index([userId, course, createdAt])
  @@index([conceptId])
  @@map("sage_coach_sessions")
}
