# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/ap_smartprep"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (for verification and password reset) ───────────────────────────────
# Leave EMAIL_SERVER_USER blank in dev to auto-bypass email verification
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="AP SmartPrep <noreply@apsmartprep.com>"

# ════════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS — Multi-cascade: system tries each in order until one succeeds.
# Add at least ONE key. All listed providers have free tiers.
# ════════════════════════════════════════════════════════════════════════════════

# 1. Google Gemini (PRIMARY — free 1,500 req/day)
#    Sign up: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# 2. Groq (BACKUP — free, ultra-fast Llama 3.3 70B)
#    Sign up: https://console.groq.com → API Keys → Create
GROQ_API_KEY="your-groq-api-key"

# 3. Together.ai (free $1 credit on sign-up, Llama 3 70B)
#    Sign up: https://api.together.xyz
TOGETHER_AI_API_KEY="your-together-ai-api-key"

# 4. OpenRouter (aggregator — routes to free models like Gemini Flash)
#    Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"

# 5. HuggingFace Inference API (free tier, Mistral-7B)
#    Sign up: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY="your-huggingface-api-key"

# 6. Cohere (free tier, Command-R)
#    Sign up: https://dashboard.cohere.com/api-keys
COHERE_API_KEY="your-cohere-api-key"

# 7. Anthropic Claude (paid, used as last resort)
#    Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key"

# 8. Ollama (self-hosted local AI — no internet required)
#    Install: https://ollama.com  then run: ollama pull llama3
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# 9. Google Vertex AI (GCP — advanced, uses service account JSON)
VERTEX_AI_PROJECT_ID="your-gcp-project-id"
VERTEX_AI_LOCATION="us-central1"
# Paste your full service-account JSON as a single-line string:
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"..."}'

# NOTE: Pollinations.ai is always available as the final fallback — no key needed.
# It provides GPT-4o-mini quality responses at no cost.

# ════════════════════════════════════════════════════════════════════════════════
# FREE EDUCATIONAL DATA APIs — no keys required, built-in.
# ════════════════════════════════════════════════════════════════════════════════
